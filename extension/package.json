{
  "name": "pureflow",
  "displayName": "PureFlow",
  "description": "A workspace-first VSCodium environment with focused documentation, mentoring, and proof tools.",
  "version": "0.1.0",
  "publisher": "yava-code",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other", "Themes"],
  "keywords": ["ide", "workspace", "mentoring", "documentation", "practice", "monad"],
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "icon": "media/extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yava-code/PureFlow.git"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Local workspace and mentor tools remain available. Configured coach calls are disabled and workspace-defined network settings are ignored until the folder is trusted.",
      "restrictedConfigurations": [
        "pureflow.coachEndpoint",
        "pureflow.coachModel",
        "pureflow.monadContractAddress",
        "pureflow.monadRpcUrl",
        "pureflow.companionUrl",
        "pureflow.aiExtensionIds"
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "pureflow.open",
        "title": "PureFlow: Open Workbench",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "pureflow.openProject",
        "title": "PureFlow: Open Project"
      },
      {
        "command": "pureflow.createProject",
        "title": "PureFlow: Create Project"
      },
      {
        "command": "pureflow.openTerminal",
        "title": "PureFlow: Open Integrated Terminal"
      },
      {
        "command": "pureflow.explainSelection",
        "title": "PureFlow: Explain Selected Code"
      },
      {
        "command": "pureflow.explainWhy",
        "title": "PureFlow: Why Is This Code Written This Way?"
      },
      {
        "command": "pureflow.quizSelection",
        "title": "PureFlow: Quiz Me on Selected Code"
      },
      {
        "command": "pureflow.quizCurrentFunction",
        "title": "PureFlow: Quiz Me on Current Function"
      },
      {
        "command": "pureflow.reviewReasoning",
        "title": "PureFlow: Review My Reasoning"
      },
      {
        "command": "pureflow.inspectMonadSelection",
        "title": "PureFlow: Inspect Address or Transaction on Monad"
      },
      {
        "command": "pureflow.runMonadDoctor",
        "title": "PureFlow: Run Monad Project Doctor"
      },
      {
        "command": "pureflow.openSourceControl",
        "title": "PureFlow: Open Source Control"
      },
      {
        "command": "pureflow.startRep",
        "title": "PureFlow: Start Focus Rep"
      },
      {
        "command": "pureflow.finishRep",
        "title": "PureFlow: Finish Focus Rep"
      },
      {
        "command": "pureflow.searchSelection",
        "title": "PureFlow: Find Selected Symbol in Documentation"
      },
      {
        "command": "pureflow.configureCoach",
        "title": "PureFlow: Configure Optional Coach (Groq / OpenAI-compatible)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pureflow",
          "title": "PureFlow",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "pureflow": [
        {
          "type": "webview",
          "id": "pureflow.console",
          "name": "Workbench"
        }
      ]
    },
    "submenus": [
      {
        "id": "pureflow.editorActions",
        "label": "PureFlow"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "pureflow.editorActions",
          "when": "editorTextFocus",
          "group": "navigation@90"
        }
      ],
      "pureflow.editorActions": [
        {
          "command": "pureflow.explainSelection",
          "when": "editorHasSelection",
          "group": "1_mentor@1"
        },
        {
          "command": "pureflow.explainWhy",
          "when": "editorHasSelection",
          "group": "1_mentor@2"
        },
        {
          "command": "pureflow.quizSelection",
          "when": "editorHasSelection",
          "group": "1_mentor@3"
        },
        {
          "command": "pureflow.quizCurrentFunction",
          "when": "editorTextFocus && !editorHasSelection",
          "group": "1_mentor@3"
        },
        {
          "command": "pureflow.reviewReasoning",
          "when": "editorHasSelection",
          "group": "1_mentor@4"
        },
        {
          "command": "pureflow.searchSelection",
          "when": "editorHasSelection",
          "group": "2_docs@1"
        },
        {
          "command": "pureflow.inspectMonadSelection",
          "when": "editorHasSelection",
          "group": "3_monad@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pureflow.open",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "pureflow.searchSelection",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "editorTextFocus"
      },
      {
        "command": "pureflow.explainWhy",
        "key": "ctrl+alt+y",
        "mac": "ctrl+alt+y",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "PureFlow",
      "properties": {
        "pureflow.coachEndpoint": {
          "type": "string",
          "default": "",
          "description": "Optional OpenAI-compatible chat completions endpoint (e.g. https://api.groq.com/openai/v1/chat/completions). Never called during an active Focus Rep. API keys use SecretStorage, not this setting."
        },
        "pureflow.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Reveal the PureFlow Workbench sidebar after the editor finishes starting. Enabled in the PureFlow portable distribution."
        },
        "pureflow.coachModel": {
          "type": "string",
          "default": "",
          "description": "Model identifier for the optional coach endpoint (for Groq, a current Groq model id such as llama-3.3-70b-versatile)."
        },
        "pureflow.monadContractAddress": {
          "type": "string",
          "default": "0xB51B276e6Ee9Cad8181C368bbF6d6efB82c154c8",
          "description": "Deployed Monad Testnet RepRegistry address used to prepare privacy-safe attestations."
        },
        "pureflow.monadRpcUrl": {
          "type": "string",
          "default": "https://testnet-rpc.monad.xyz",
          "description": "Monad Testnet JSON-RPC endpoint used by the read-only workspace lens. The endpoint must report chain ID 10143."
        },
        "pureflow.companionUrl": {
          "type": "string",
          "default": "https://yava-code.github.io/PureFlow/",
          "description": "PureFlow web companion used for public verification and user-controlled wallet handoff."
        },
        "pureflow.aiExtensionIds": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "github.copilot",
            "github.copilot-chat",
            "github.copilot-chat-vscode",
            "anthropic.claude-code",
            "continue.continue",
            "codeium.codeium",
            "tabnine.tabnine-vscode",
            "sourcegraph.cody-ai",
            "supermaven.supermaven",
            "saoudrizwan.claude-dev",
            "rooveterinaryinc.roo-cline",
            "kilocode.kilo-code",
            "amazonwebservices.amazon-q-vscode",
            "google.geminicodeassist"
          ],
          "description": "Extension IDs reported before a Focus Rep when present in this profile. The portable launcher also disables a core set at start."
        }
      }
    },
    "themes": [
      {
        "label": "PureFlow Mineral",
        "uiTheme": "vs-dark",
        "path": "./themes/pureflow-mineral-color-theme.json"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.9",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
