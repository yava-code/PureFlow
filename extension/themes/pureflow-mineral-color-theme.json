{
  "$schema": "vscode://schemas/color-theme",
  "name": "PureFlow Mineral",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#CED8D6",
    "descriptionForeground": "#82918F",
    "disabledForeground": "#64716F99",
    "focusBorder": "#3A9695",
    "errorForeground": "#E17B72",
    "icon.foreground": "#8FA09D",
    "selection.background": "#285F6159",
    "textLink.foreground": "#63B9B5",
    "textLink.activeForeground": "#86D1CC",
    "button.background": "#287876",
    "button.foreground": "#F2FAF8",
    "button.hoverBackground": "#32918E",
    "button.secondaryBackground": "#263332",
    "button.secondaryForeground": "#C8D3D1",
    "button.secondaryHoverBackground": "#31413F",
    "input.background": "#101716",
    "input.border": "#2D3B39",
    "input.foreground": "#D3DDDB",
    "input.placeholderForeground": "#697875",
    "inputOption.activeBorder": "#429E9C",
    "dropdown.background": "#141C1B",
    "dropdown.border": "#2D3B39",
    "dropdown.foreground": "#CED8D6",
    "badge.background": "#285F5E",
    "badge.foreground": "#E8F5F2",
    "progressBar.background": "#3AA19E",
    "titleBar.activeBackground": "#0B100F",
    "titleBar.activeForeground": "#D4DEDC",
    "titleBar.inactiveBackground": "#0B100F",
    "titleBar.inactiveForeground": "#73817F",
    "activityBar.background": "#0A0F0E",
    "activityBar.foreground": "#D7E3E0",
    "activityBar.inactiveForeground": "#657370",
    "activityBar.activeBorder": "#4DADAA",
    "activityBarBadge.background": "#2C8986",
    "activityBarBadge.foreground": "#F3FAF8",
    "sideBar.background": "#0E1413",
    "sideBar.foreground": "#B9C5C2",
    "sideBar.border": "#202B29",
    "sideBarTitle.foreground": "#D4DEDC",
    "sideBarSectionHeader.background": "#121A19",
    "sideBarSectionHeader.foreground": "#AAB8B5",
    "sideBarSectionHeader.border": "#202B29",
    "list.activeSelectionBackground": "#234442",
    "list.activeSelectionForeground": "#E1EEEB",
    "list.inactiveSelectionBackground": "#182725",
    "list.hoverBackground": "#16211F",
    "list.highlightForeground": "#62B7B3",
    "editorGroup.border": "#202B29",
    "editorGroupHeader.tabsBackground": "#0B1110",
    "editorGroupHeader.noTabsBackground": "#0B1110",
    "tab.activeBackground": "#111817",
    "tab.activeForeground": "#D8E3E0",
    "tab.activeBorderTop": "#4DADAA",
    "tab.inactiveBackground": "#0B1110",
    "tab.inactiveForeground": "#71807D",
    "tab.border": "#202B29",
    "editor.background": "#111817",
    "editor.foreground": "#C9D4D2",
    "editorLineNumber.foreground": "#43514E",
    "editorLineNumber.activeForeground": "#83918E",
    "editorCursor.foreground": "#67C4C0",
    "editor.selectionBackground": "#275F6059",
    "editor.inactiveSelectionBackground": "#28444359",
    "editor.lineHighlightBackground": "#16201E",
    "editorIndentGuide.background1": "#24302E",
    "editorIndentGuide.activeBackground1": "#3C514E",
    "editorWhitespace.foreground": "#2D3A38",
    "editorBracketMatch.background": "#347B793D",
    "editorBracketMatch.border": "#4FAAA6",
    "editorGutter.addedBackground": "#4E9E78",
    "editorGutter.modifiedBackground": "#4D8FA8",
    "editorGutter.deletedBackground": "#C26762",
    "editorError.foreground": "#E17B72",
    "editorWarning.foreground": "#D8A757",
    "editorInfo.foreground": "#63A9C0",
    "editorHint.foreground": "#5BAE9C",
    "peekView.border": "#347C79",
    "peekViewEditor.background": "#101716",
    "peekViewResult.background": "#0C1211",
    "panel.background": "#0D1312",
    "panel.border": "#273331",
    "panelTitle.activeBorder": "#4DADAA",
    "panelTitle.activeForeground": "#D4DEDC",
    "panelTitle.inactiveForeground": "#74817F",
    "terminal.background": "#0D1312",
    "terminal.foreground": "#C8D3D1",
    "terminal.ansiBlack": "#18201F",
    "terminal.ansiRed": "#D97770",
    "terminal.ansiGreen": "#6FB48B",
    "terminal.ansiYellow": "#D4A85E",
    "terminal.ansiBlue": "#72A7C5",
    "terminal.ansiMagenta": "#B592C6",
    "terminal.ansiCyan": "#63B5B1",
    "terminal.ansiWhite": "#C8D3D1",
    "terminal.ansiBrightBlack": "#60706D",
    "terminal.ansiBrightRed": "#ED8C84",
    "terminal.ansiBrightGreen": "#86C99F",
    "terminal.ansiBrightYellow": "#E6BC73",
    "terminal.ansiBrightBlue": "#8BBBD4",
    "terminal.ansiBrightMagenta": "#C8A5D5",
    "terminal.ansiBrightCyan": "#7ACCC7",
    "terminal.ansiBrightWhite": "#ECF4F2",
    "statusBar.background": "#10201E",
    "statusBar.foreground": "#BFD0CD",
    "statusBar.border": "#23413E",
    "statusBar.debuggingBackground": "#715329",
    "statusBar.debuggingForeground": "#FFF7E7",
    "statusBar.noFolderBackground": "#121918",
    "statusBar.noFolderForeground": "#8E9C99",
    "menu.background": "#121918",
    "menu.foreground": "#C9D4D2",
    "menu.selectionBackground": "#244A47",
    "menu.selectionForeground": "#EDF7F5",
    "menu.separatorBackground": "#2A3735",
    "notifications.background": "#151D1C",
    "notifications.foreground": "#C9D4D2",
    "notificationCenter.border": "#2B3937"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#65736F", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#8ABFC1" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#A9C7B0" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": { "foreground": "#D0B780" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#A7BE88" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#C59E88" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name"],
      "settings": { "foreground": "#C9D4D2" }
    },
    {
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#B7C9C4" }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#82908D" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#F2C6C1", "background": "#6C302D" }
    }
  ]
}
